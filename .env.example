APP_NAME=SignalFlow
ENVIRONMENT=development
# Note: SQLite variables removed — project migrated to Supabase Postgres
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWT_SECRET=your-jwt-secret

ENCRYPTION_KEY=

# APIFY_API_TOKEN=  # DEPRECATED — no longer needed, Reddit public JSON used instead

# Database connection (Postgres) — used by auto-migration on deploy.
# Get this from Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Only set this in deployment environments; local dev uses Supabase REST API.
DATABASE_URL=

# LLM Provider selection (gemini, openai, perplexity, claude)
# Gemini is the primary/default provider for SignalFlow. Only the active
# provider's API key is required; unused providers are silently skipped.
LLM_PROVIDER=gemini

# Gemini (primary — required unless you switch LLM_PROVIDER)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI (optional alternative — leave blank unless LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Perplexity (optional alternative — leave blank unless LLM_PROVIDER=perplexity)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Anthropic / Claude (optional alternative — leave blank unless LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

REDDIT_BASE_URL=https://old.reddit.com
REDDIT_USER_AGENT=web:signalflow:v1.0 (by /u/SignalFlowBot)
REDDIT_SEARCH_PROVIDER=auto
# Optional search providers for external Reddit URL discovery.
# Leave these unset to use DuckDuckGo HTML scraping with no API key.
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
SMTP_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# APIFY_API_TOKEN=  # DEPRECATED — no longer needed, Reddit public JSON used instead

# --- Multi-Platform Social Scraping (RapidAPI) ---
# One key covers all platforms. Sign up free at https://rapidapi.com
# Subscribe to each platform's API on the RapidAPI marketplace (free tiers available).
#
# Subscribe to each API on https://rapidapi.com (one key works for all):
#   Reddit:    ReddAPI                       (reddapi.p.rapidapi.com)
#   Twitter/X: Twitter154                    (twitter154.p.rapidapi.com)
#   Instagram: Instagram Looter2             (instagram-looter2.p.rapidapi.com)
#   LinkedIn:  Fresh LinkedIn Scraper API    (fresh-linkedin-scraper-api.p.rapidapi.com)
RAPIDAPI_KEY=

# --- Multi-Agent Platform ---

# Local LLM via Ollama (optional — enables free local AI generation)
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1

# Local embeddings (optional — enables semantic similarity without paid APIs)
# Use "tfidf" for pure Python fallback, or "sentence-transformers" for ONNX MiniLM
EMBEDDING_MODEL=tfidf

# Relevance scoring thresholds (0-100, 0.0-1.0)
RELEVANCE_THRESHOLD=70
SEMANTIC_THRESHOLD=0.45

# Default lookback for agent fetches (days)
DEFAULT_LOOKBACK_DAYS=7

# Platform API toggles (manual mode if false, API mode if true + credentials present)
ENABLE_X_API=false
ENABLE_LINKEDIN_API=false
ENABLE_HN_API=true

# Reddit OAuth (optional — only needed for account connection)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=

